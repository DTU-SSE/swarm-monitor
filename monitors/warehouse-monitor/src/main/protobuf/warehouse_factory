syntax = "proto3";

package warehouse_factory;

message Meta {

    bool is_local_event = 3;
    repeated string tags = 4;
    uint64 timestamp_micros = 5;
    uint32 lamport = 6;
    string app_id = 7;
    string event_id = 8;
    string stream = 9;
    uint32 offset = 10;
}

message PartRequest {

    string part_name = 3;
    Meta meta = 1;
    string lbj = 2;
}

message PartOK {

    string part_name = 3;
    Meta meta = 1;
    string lbj = 2;
}

message Position {

    string position = 3;
    string part_name = 4;
    Meta meta = 1;
    string lbj = 2;
}

message ClosingTime {

    string time_of_day = 3;
    Meta meta = 1;
    string lbj = 2;
}

message Car {

    string part_name = 3;
    string model_name = 4;
    Meta meta = 1;
    string lbj = 2;
}

message Obs {

    Meta meta = 1;
    string lbj = 2;
}

message Report {

    string model_name = 3;
    string decision = 4;
    Meta meta = 1;
    string lbj = 2;
}

message Event {

    oneof sealed_value {

        PartRequest part_request = 3;
        PartOK part_ok = 4;
        Position position = 5;
        ClosingTime closing_time = 6;
        Car car = 7;
        Obs obs = 8;
        Report report = 9;
    }
}