{
  "name": "car-factory",
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "build": "tsc",
    "start-steel-transport": "node dist/src/machine_drivers/steel_press_protocol/run_steel_transport.js",
    "start-stamp": "node dist/src/machine_drivers/steel_press_protocol/run_stamp.js",
    "start-body-assembler": "node dist/src/machine_drivers/steel_press_protocol/run_body_assembler.js",
    "start-car-body-checker": "node dist/src/machine_drivers/steel_press_protocol/run_car_body_checker.js",
    "start-painter": "node dist/src/machine_drivers/paint_shop_protocol/run_painter.js",
    "start-basic-transport": "node dist/src/machine_drivers/warehouse_protocol/run_basic_transport.js",
    "start-smart-transport": "node dist/src/machine_drivers/warehouse_protocol/run_smart_transport.js",
    "start-base-station": "node dist/src/machine_drivers/warehouse_protocol/run_base_station.js",
    "start-engine-installer": "node dist/src/machine_drivers/engine_installation_protocol/run_engine_installer.js",
    "start-engine-checker": "node dist/src/machine_drivers/engine_installation_protocol/run_engine_checker.js",
    "start-warehouse": "node dist/src/machine_drivers/engine_installation_protocol/run_warehouse.js",
    "start-wheel-installer": "node dist/src/machine_drivers/wheel_installation_protocol/run_wheel_installer.js",
    "start-wheel-checker": "node dist/src/machine_drivers/wheel_installation_protocol/run_wheel_checker.js",
    "start-window-installer": "node dist/src/machine_drivers/window_installation_protocol/run_window_installer.js",
    "start-window-checker": "node dist/src/machine_drivers/window_installation_protocol/run_window_checker.js",
    "start-quality-control": "node dist/src/machine_drivers/quality_control_protocol/run_quality_control.js",
    "prestart-stamp": "npm run compile-proto",
    "prestart-body-assembler": "npm run compile-proto",
    "compile-proto": "npx tsx scripts/compile_protobuf.ts protos/car_factory.proto src/generated/car_factory.ts",
    "prestart-forwarder": "npm run compile-proto",
    "start-forwarder": "node dist/src/forwarder.js",
    "start-spawner": "node dist/src/spawner.js",
    "start-spawner-silent": "node dist/src/spawner_silent.js",
    "start-spawner-silent-multiple-per-process": "node dist/src/spawner_silent_multiple_machines_per_process.js",
    "start-machine-spawner": "npx tsx src/spawn_machines.tsx"
  },
  "devDependencies": {
    "@protobuf-ts/plugin": "^2.11.1",
    "@protobuf-ts/runtime": "^2.11.1",
    "@types/async": "^3.2.25",
    "@types/lodash.camelcase": "^4.3.9",
    "@types/node": "^24.6.2",
    "@types/react": "^19.2.0",
    "@types/yargs": "^17.0.33",
    "tsx": "^4.20.6",
    "typescript": "^5.9.2"
  },
  "dependencies": {
    "@actyx/machine-check": "file:./vendor/actyx-machine-check-0.3.1.tgz",
    "@actyx/machine-runner": "file:./vendor/actyx-machine-runner-0.5.7.tgz",
    "@actyx/sdk": "^0.5.10",
    "async": "^3.2.6",
    "chalk": "^5.6.0",
    "execa": "^9.6.0",
    "ink": "^6.3.1",
    "ink-spinner": "^5.0.0",
    "lodash.camelcase": "^4.3.0",
    "ora": "^9.0.0",
    "react": "^19.2.0",
    "yargs": "^18.0.0"
  }
}
