#!/usr/bin/env bash

port="9999"
address=""

while getopts ":a:p:" opt; do
    case "${opt}" in
        a)
            address=$OPTARG
            ;;
        p)
            port=$OPTARG
            ;;
        :)
            echo "Option -$OPTARG requires an argument"
            exit 1
            ;;
        *)
            echo "Invalid option -$OPTARG"
            exit 1
        ;;
    esac
done

if [ -z "$address" ]; then
    echo "Supply the address of the monitor -a <ADDRESS>"
    exit 1
fi

cd swarms/factory
exec ./start_factory_forwarding.sh "session1" "$address" "$port" "/dev/null" "/dev/null"
